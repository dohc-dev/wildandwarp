	quest.25D87D5522FD4861.title: "Chorus Fruit?"
	quest.265DEDBF34CB37AF.quest_desc: ["Like a Pikarang but on FIRE"]
	quest.2694808D51042470.title: "Gold Backpack"
	quest.26D2235E1F464F42.quest_desc: ["The **Inception Upgrade** is a unique, high-tier upgrade that allows you to put a backpack *inside* another backpack."]
	quest.26D2235E1F464F42.quest_subtitle: "Backpacks within Backpacks."
	quest.26D2235E1F464F42.title: "Inception Upgrade"
