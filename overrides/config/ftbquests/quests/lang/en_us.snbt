	quest.44DBEF7E43052868.quest_desc: ["A propeller for generating thrust"]
	quest.452652A47626C707.quest_desc: ["Moveable soul campfire"]
	quest.45B87D51EF224B8C.quest_desc: ["The **Sample Drill** is your initial prospecting tool. Place it on a block, power it with a backtank, and wait for a sample to be returned. This tells you what ore is in the ground."]
