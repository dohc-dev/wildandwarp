	quest.5F1AD904545650BB.quest_desc: ["crush some wheat in a millstone or crushing wheel! "]
	quest.5F5DB67F6A470C73.quest_desc: ["This milestone tracks when your armed forces reach a size of **30** guards, enabling strong defense and potential expeditions."]
	quest.5F5DB67F6A470C73.title: "Military Strength: 30 Guards"
	quest.5F63D37E41C07B2E.quest_desc: ["Like an anvil but no repair costs! "]
	quest.5F883CD530B2AE07.quest_desc: ["**Create: Ore Excavation Plus** introduces multi-step processing. Crush your Raw Diamond/Emerald to dust, then **Cut** or **Wash** the Raw Gems to start the chain."]
	quest.5F883CD530B2AE07.title: "The Processing Chain"
	quest.5FC01763770A062E.quest_desc: ["This advancement triggers upon completing the building of the Town Hall structure after it was initially placed as the control block. This is a crucial milestone!"]
	quest.5FC01763770A062E.title: "The Town Hall is Complete"
	quest.6012A593D0FB81EC.quest_desc: ["The **Kitchen Hut** is an upgrade to the Cook Hut, allowing for more complex and better quality meals, which boosts citizen happiness and health."]
	quest.6012A593D0FB81EC.title: "Advanced Food: Kitchen Hut"
	quest.60777D98CE917817.quest_desc: ["The **Cooking Pot** is vital for making complex meals, like stews and soups, which offer high saturation and beneficial effects."]
	quest.60777D98CE917817.title: "The Essential Pot"
	quest.627AEB414599E31E.quest_desc: ["Ponder me!"]
	quest.6289C9F19ED553A1.quest_desc: ["A redstone link with a visual cone, it can only see links infont."]
	quest.629658E9AB4D46F1.quest_desc: ["Symmetric sails have more drag, good for turning. use regular sails for lift"]
	quest.634B2E7FB2183363.quest_desc: ["**Tetra** weapons offer capabilities beyond standard blades. Forge a new sword and explore the world with enhanced combat power!"]
	quest.634B2E7FB2183363.title: "Advanced Bladecraft"
	quest.638EB4E35F41405B.quest_desc: ["Upgrade bases are required to craft all functional upgrades. This is the **Backpack-specific** version (distinguished by its **Leather** texture)."]
	quest.638EB4E35F41405B.quest_subtitle: "For Backpacks"
	quest.638EB4E35F41405B.title: "Backpack Upgrade Base"
	quest.63FE80143DB276C3.quest_desc: ["Throw away fluids"]
	quest.64407A1BC7A1761B.quest_desc: ["Get some nuggers of experiance by crushing stuff! like ores or mobs."]
	quest.64407A1BC7A1761B.quest_subtitle: "Start of the exp journey"
	quest.647F95EED59927B7.quest_desc: ["The **Cook Hut** takes raw food (from Farmers, Fishermen, etc.) and processes it into edible, health-restoring meals for the citizens. Essential for growing the population."]
	quest.647F95EED59927B7.title: "Cook Hut"
	quest.653C032CF52802A0.quest_desc: ["The **Chthonic Extractor** is a component for your hammer that allows you to upgrade its capabilities, notably enabling a **3x3 mining area**."]
	quest.653C032CF52802A0.title: "The Extractive Upgrade"
	quest.65BE8DB8C5C357D5.quest_desc: ["works on wood!"]
	quest.65D23E7683812E26.quest_desc: ["Citizens are not picky. They will consume any edible item you place in storage, even **Rotten Flesh**! This is helpful in emergencies or automating early food supply."]
	quest.65D23E7683812E26.title: "Citizens Eat Anything!"
	quest.65EC649FCC1F3F4F.quest_desc: ["Stress units from FE POWER"]
	quest.6615CE64DC0565EC.quest_desc: ["**Straw** is obtained by harvesting tall grass with a knife, and is used for crafting **Rope** and decorating your farm."]
	quest.6615CE64DC0565EC.title: "A Simple Byproduct"
	quest.667A91871415DF44.quest_desc: ["Horizontal fluid tank"]
	quest.67E8B8DCFC93F832.quest_desc: ["The **Warehouse** is vital for logistics. It stores all produced resources and allows the **Deliveryman** to deliver materials to Builders. You must build this early!"]
	quest.67E8B8DCFC93F832.title: "The Warehouse: Storage Hub"
	quest.68500900087F92BC.quest_desc: ["The **Sawmill** can be programmed to craft specific blocks needed for your colony. This advancement confirms you have added the recipe for a door, a common building component."]
	quest.68500900087F92BC.title: "Sawmill Production: Doors"
	quest.68BA5151F22C7CC5.quest_desc: ["Craft this advanced belt to conveniently store numerous tools and items, making them easily accessible in the field."]
	quest.68BA5151F22C7CC5.title: "The Enhanced Utility Belt"
	quest.68FC81E133443E76.quest_desc: ["The **Library** is where the **Scholar** works, researching technology and increasing the max skill level of all workers. Essential for high-tier colony progress."]
	quest.68FC81E133443E76.title: "Advanced Research: Library"
	quest.696BDC29ACCBBE29.quest_desc: ["The **Undertaker Totem** is a powerful late-game upgrade to the Graveyard, allowing for more efficient resurrection and burial services."]
	quest.696BDC29ACCBBE29.title: "Endgame: Undertaker Totem"
	quest.69EAF1072D492F1A.quest_desc: ["The **Ancient Tome** is a rare item that can be found via exploration or occasionally traded for. It is required for upgrading high-tier buildings."]
	quest.69EAF1072D492F1A.title: "Resource: Ancient Tome"
	quest.69F9DB75244E6B3B.quest_desc: ["Wands for building! CTRL+SHIFT+RIGHT CLICK in the air to open the menu!"]
	quest.69F9DB75244E6B3B.title: "Construction Wands!"
	quest.6A46C70D8A7DBC04.quest_desc: ["its useless without something in it"]
	quest.6A60B76053393288.quest_desc: ["The **Smeltery Hut** processes raw ores (like iron) into ingots for use in other production chains like the Blacksmith."]
	quest.6A60B76053393288.title: "Advanced Metal: Smeltery Hut"
	quest.6A84CD0EE4833294.quest_desc: ["**Tetra** allows for the modification of shields, granting them superior protection and even new offensive capabilities. Try customizing a shield in the workbench!"]
	quest.6A84CD0EE4833294.title: "Reinforced Defense"
	quest.6B0CE8AD86991E28.quest_desc: ["The **Composter Hut** turns organic waste into **Bone Meal**, which is essential for speeding up farm growth and other related production buildings."]
	quest.6B0CE8AD86991E28.title: "Production: Composter Hut"
	quest.6B26495A9E7D77FC.quest_desc: ["This is an early population goal! You need at least **5** citizens to begin running basic jobs and making the colony self-sufficient."]
	quest.6B26495A9E7D77FC.title: "Population Milestone: 5 Citizens"
	quest.6B2D00B54B16464B.quest_desc: ["Storage can act as an automated processing station. The **Smelting, Smoking, and Blasting Upgrades** add portable versions of the furnace trio."]
	quest.6B2D00B54B16464B.title: "Smelting and Smoking Upgrades"
	quest.6B7759342D4AE496.quest_desc: ["The **Stack Upgrades** multiply the maximum stack size an item can reach in the backpack, allowing you to hold massive amounts of common resources. The **Starter** tier is a great entry point."]
	quest.6B7759342D4AE496.quest_subtitle: "Multiply your stack size!"
	quest.6B7759342D4AE496.title: "Stack Upgrades (Starter to T4)"
	quest.6BB0C51EE8CA5966.quest_desc: ["The **Miner Hut** automatically digs and collects resources in a deep mine shaft (set the boundaries). Miners will require tools and torches to work safely."]
	quest.6BB0C51EE8CA5966.title: "Miner Hut"
	quest.6CAD31E853C5AABD.quest_desc: ["The **Knife** is the most essential tool, used for harvesting, slicing, and preparing food ingredients."]
	quest.6CAD31E853C5AABD.title: "Chef's Precision"
	quest.6CE7AC11D89F7998.quest_desc: ["No more lava everywhere"]
	quest.6D56AD1BEC644A10.quest_desc: ["The **Archery** range trains your guards in ranged combat, allowing them to use bows and crossbows more efficiently from their Guard Towers."]
	quest.6D56AD1BEC644A10.title: "Military: Archery Range"
	quest.6DE2AA3A79F054DE.quest_desc: ["The **Void Upgrade** deletes unwanted items automatically based on a filter. The **Advanced** version can target specific slots or items for destruction."]
	quest.6DE2AA3A79F054DE.quest_subtitle: "Eliminate junk loot."
	quest.6DE2AA3A79F054DE.title: "Void Upgrades"
	quest.6E47004B5BA60AAC.quest_desc: ["The **Void Upgrade** automatically discards items placed in the storage block, useful for overflow protection and junk removal."]
	quest.6E47004B5BA60AAC.title: "Void Upgrades"
	quest.6E925E17FB4454E2.quest_desc: [
		"Automatically trade with villagers! "
		""
		"Note: Villagers only trade during normal working hours"
	]
	quest.6EA68A15ABAB2D7D.quest_desc: ["Turn your blaze into a SUPER BLAZE, just be careful of the explosion..."]
	quest.6EE28FF64778030F.quest_desc: ["Collect all of the **Tools of War Scrolls** from various chests to complete your collection of Warforge schematics!"]
	quest.6EE28FF64778030F.title: "The Full Warchest"
	quest.6EEA012FA11C7C08.quest_desc: ["You must first claim the land your colony will occupy. Craft and use the **Supply Deployer** to place a temporary supply chest and claim your territory. Be careful of mobs!"]
	quest.6EEA012FA11C7C08.title: "Claim Your Territory"
	quest.6EEDD37CBB070FCE.quest_desc: [
		"Welcome to the beginning of your journey!"
		"This pack mixes Create, Aeronautics and Minecolonies into one unified adventure."
	]
	quest.6EEDD37CBB070FCE.title: "Welcome to Your Adventure"
	quest.6F26C02744F415BE.quest_desc: ["Collect all of the **Tools of War Scrolls** from various chests to complete your collection of Warforge schematics!"]
	quest.6F26C02744F415BE.title: "The Full Warchest"
	quest.6F4069D2C20C472A.quest_desc: ["DRONE INNIT!"]
	quest.6FD5A1B2FC94F47A.quest_desc: ["OP sandpaper"]
	quest.70457BBE36DC7C91.quest_desc: ["Once you have the xp stored in a tank, all you need to get the xp orbs to fall back onto the player all you need is a pump and pipe with nothing on the end this will pull the liquid xp down and dispense the orbs for the player to pick up"]
	quest.70457BBE36DC7C91.quest_subtitle: "Getting back the xp"
	quest.70457BBE36DC7C91.title: "Dispensing XP onto the player"
	quest.7068CA538D7F8D85.quest_desc: ["A clutch but backwards"]
	quest.7078F6E8A179D88F.quest_desc: ["A redstone link that adds wireless redstone to buttons and levers without using extra space!"]
	quest.70DC1CF6F284E511.quest_desc: ["runs a redstone sequence when powered"]
	quest.714D87B91E1B61C6.quest_desc: ["Obtain Magnitite by mining"]
	quest.71CAD1D9089778BC.quest_desc: ["Crafting **Rope** is a versatile recipe, useful for decorating, building, or moving items vertically. Also craft a **Straw Bale** for storage/decoration."]
	quest.71CAD1D9089778BC.title: "Farmstead Ropework"
	quest.71D7D48518966ACD.quest_desc: [
		"Use ponder to help you make the Pumpjack"
		""
		"(you can pump oil from stone)"
	]
	quest.71FCF06A98CC66D7.quest_desc: ["The **Clipboard** is a useful tool that shows the building being constructed in the selected Builder's Hut, and the resources it currently needs."]
	quest.71FCF06A98CC66D7.title: "Utility: Clipboard"
	quest.7207BECD0E0823BD.quest_desc: ["Holds liquids"]
	quest.721E56DA0C8D8E0B.quest_desc: ["A mechanical bearing for simulated contraptions, can be loosened with a redstone signal"]
	quest.72B78E193A7D0D0E.quest_desc: ["Shafts Pass through eachother"]
	quest.72C749AD9F1C634E.quest_desc: ["The **Citizen Advancement** triggers upon recruiting your very first citizen! This usually happens automatically once the Town Hall and a residential building are complete."]
	quest.72C749AD9F1C634E.title: "First Citizen Recruited"
	quest.73095092A407F1C5.quest_desc: ["**Scrolls** are essential in **Tetra** as they unlock superior forging options, new modules, and unique abilities for your tools. Find them in dungeons or through trade."]
	quest.73095092A407F1C5.title: "Unlocking Ancient Schematics"
	quest.730AE43A347E79B8.quest_desc: ["like a fluid pipe but for &4HEAT&r"]
	quest.737A75B259638C31.quest_desc: ["The **Insulated Plate** (Vent Plate) is an excellent material for shields, offering significantly increased durability and resilience."]
	quest.737A75B259638C31.title: "Reinforced Platework"
	quest.73847BA3D73B8301.quest_desc: ["A BIG Diesel engine!"]
	quest.73B5FE87143963D3.quest_desc: ["Turn experiance into &6SUPER EXPERIANCE&r using &9LIGHTNING&r "]
	quest.743D7D9204915A13.quest_desc: ["When a citizen dies, they leave behind a grave. Another citizen (the Undertaker) will travel to the grave to mourn and bury the deceased. This advancement triggers upon the first burial."]
	quest.743D7D9204915A13.title: "Citizen Burial"
	quest.74615FBE8C93952D.quest_desc: ["The **Smelting Upgrade** adds a portable Furnace to your backpack. The **Auto-Smelting** tier can pull fuel and run automatically."]
	quest.74615FBE8C93952D.quest_subtitle: "A furnace on your back."
	quest.74615FBE8C93952D.title: "Smelting and Auto-Smelting"
	quest.74C114D0C0D4D374.quest_desc: ["The **Hospital** heals sick or injured citizens, preventing deaths and ensuring your workforce remains healthy and productive."]
	quest.74C114D0C0D4D374.title: "Support: Hospital"
	quest.74FE0EF7A62B7CF4.quest_desc: ["a clutch that only connects if the input is faster than the threshhold"]
	quest.75165E16BE3CA30C.quest_desc: ["The **Feeding Upgrade** automatically feeds you food stored in the backpack. The **Advanced** tier can also heal you using consumables."]
	quest.75165E16BE3CA30C.quest_subtitle: "Keep hunger satisfied."
	quest.75165E16BE3CA30C.title: "Feeding Upgrades"
	quest.75599A9909C7A8C8.quest_desc: [
		"Your citizens must eat to survive. Place food, especially bread, apples, or complex meals, in the **Town Hall** or **Warehouse** for distribution."
		"This advancement confirms your first citizen has eaten and is happy."
	]
	quest.75599A9909C7A8C8.title: "First Meal Consumed"
	quest.75F673C50C17DFC6.quest_desc: ["connect this to the other side fo your &2Reactor Rod&r"]
	quest.7614FDF43E0AAD07.quest_desc: ["Throw away items"]
	quest.76C8626BF50E7479.quest_desc: ["provides an interface to access two inventories at the same time!"]
	quest.775BB7E7E6C492A1.quest_desc: ["OIL "]
	quest.77A2704F9551D0B5.quest_desc: ["The **Jukebox Upgrade** lets you play records right from your backpack. The **Anvil Upgrade** provides portable repair and naming functionality."]
	quest.77A2704F9551D0B5.quest_subtitle: "Entertainment and maintenance."
	quest.77A2704F9551D0B5.title: "Jukebox and Anvil Upgrades"
	quest.77C92B58EF226277.quest_desc: ["The sheer variety of these functional armors makes for a great cosmetic collection. Collect one of every helmet type for your armory display!"]
	quest.77C92B58EF226277.title: "Collector's Goal: All Helmets"
	quest.7870800C28A7E199.quest_desc: ["The **Chicken Herder Hut** manages a flock of chickens for eggs, feathers, and chicken meat."]
	quest.7870800C28A7E199.title: "Herder: Chicken Herder Hut"
	quest.78A3A928F74E5A0A.quest_desc: ["Its a linked controller for your whole keyboard"]
	quest.78F716258C26AFC5.quest_desc: ["The **Deposit** upgrade (paired with the **Restock**) allows you to quickly dump items from your inventory into the backpack, speeding up drops after mining."]
	quest.78F716258C26AFC5.quest_subtitle: "Quickly dump inventory items."
	quest.78F716258C26AFC5.title: "Deposit Upgrades"
	quest.799E18C17D0CACCF.title: "Stonecutter Upgrade"
	quest.79A785FC05EF4F60.quest_desc: ["Ore veins are chunk based which means you might have to move some land before you can mine! Try F3+G to see chunks"]
	quest.7A068EFF6FB36B59.quest_desc: ["The **Divine Armor** is a fancy set offering exceptional protection. A full set grants a unique ability: once per minute, it fully negates the damage from one incoming attack."]
	quest.7A068EFF6FB36B59.title: "Tier 4: Divine Protection"
	quest.7A130478B5F5D8E7.quest_desc: ["This rack allows you to neatly hang your tools. Placing it next to a **workbench** grants a convenient way to access and use them for forging."]
	quest.7A130478B5F5D8E7.title: "The Handy Tool Rack"
	quest.7A1D999959471F11.quest_desc: ["An encased cogwheen that can slow down the cog when powrered wth redstone when the cog is givin rotational power the shaft speeds up."]
	quest.7A39A5B9E3CAC840.quest_desc: ["To get the liquid xp from the &6bottle o' enchanting&r you need the item drain, it will give you back the bottle after it has drained the xp"]
	quest.7A39A5B9E3CAC840.quest_subtitle: "Stealing the precious liquid xp"
	quest.7B2EF52654BC3C22.quest_desc: ["The **Refill** upgrade automatically pulls items from your backpack to refill the stack you are currently holding when it drops below a set amount."]
	quest.7B2EF52654BC3C22.quest_subtitle: "Keep your current stack full."
	quest.7B2EF52654BC3C22.title: "Refill Upgrades"
	quest.7B43A14AECC5C405.quest_desc: ["Utilize the **Stonecutter** material on your sword to gain the special ability to **sweep-mine stone** and similar blocks."]
	quest.7B43A14AECC5C405.title: "The Stone Carver Blade"
	quest.7B5E2CD676A1A1C4.quest_desc: ["The **Baker Hut** is an early food processor that turns wheat into bread, a good staple food source for your growing population."]
	quest.7B5E2CD676A1A1C4.title: "Production: Baker Hut"
	quest.7BB7CCADADDD0BA8.quest_desc: [
		"Update your hammer to tier 3"
		"(You need to build two hammer to upgrade each other)"
	]
	quest.7BB7CCADADDD0BA8.title: "Is That An Iron Hammer?"
	quest.7BE136ABD8DB4DAF.quest_desc: ["Limits the rotation to a configurable angle"]
	quest.7CEE50284584F2B3.quest_desc: ["passively generates &4HEAT&r in the daylight"]
	quest.7D01E96D16F65302.quest_desc: ["You have mastered the craft of every unique armor set the mod has to offer. Now combine your favorite pieces to create the perfect balance of utility and defense!"]
	quest.7D01E96D16F65302.title: "Final Assembly"
	quest.7DCB91AD0050DDA9.quest_desc: ["convert diesel into rotational energy! but with upgrades!"]
	quest.7E01576DB01D4C22.quest_desc: [
		"**Robe Armor** (Wool/Blaze): Dyeable, fireproof, and deals fire damage to attackers on hit. Perfect for early Nether scouting."
		"**Slime Armor** (Slime): Provides high explosion resistance and makes attackers bounce away. Requires Slime balls."
	]
	quest.7E01576DB01D4C22.title: "Tier 1: Utility and Elemental Defense"
	quest.7EB349B912AB9E1E.quest_desc: ["This **Hone Scroll** upgrade, utilized with **Gold**, increases your tool's **Magic Capacity** for more powerful enhancements."]
	quest.7EB349B912AB9E1E.title: "Piglins' Golden Insight (Hone)"
	quest.7EDFBC8BAEC5E525.quest_desc: ["used to make cylinders of all types"]
