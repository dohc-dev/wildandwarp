	quest.54A7C357AE0ADF65.title: "Diamond Backpack"
	quest.54C81018CE13F6F1.quest_desc: ["Emits a laser when powered by redstone. dyeable, black is invisible"]
	quest.55768951471D44D8.quest_desc: [
