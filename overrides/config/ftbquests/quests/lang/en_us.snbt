	quest.4DFFD56294AF6E0F.quest_desc: ["Name your simulated contraption in any color!"]
	quest.4E5A011F861FCE5A.quest_desc: ["Outputs a redstone signal based on its speed. Shows precise information when wearing goggles"]
	quest.4EAF4F9F7317CAE1.quest_desc: ["The **Pickup** upgrade absorbs nearby drops into the backpack. The **Magnet** draws items from a larger radius. Get the **Advanced** versions for increased range and filtered magnetizing!"]
	quest.4EAF4F9F7317CAE1.quest_subtitle: "Automate item collection."
	quest.4EAF4F9F7317CAE1.title: "Pickup Upgrades"
	quest.4EE36F25A452F1FC.quest_desc: ["aTurn your solid experience into liquid form!"]
	quest.4EE7DC998B846A50.quest_desc: ["Its mostly for crafting, but you can also feed these to the &6Blaze Forger&r"]
	quest.4F0DD18D7647A103.quest_desc: ["The **Sophisticated** mods bring tiered, modular storage to your world. Unlock the core concepts before diving into the Portable (Backpacks) or Static (Barrels/Chests) solutions."]
	quest.4F0DD18D7647A103.title: "Sophisticated Systems Introduction"
	quest.4F15D1EB5397C942.quest_desc: ["A gearbox with adjustable sides"]
	quest.4F1BAD0FF159CDF0.quest_desc: ["Find or plant your first **Farmer's Delight** crop, such as **Cabbage** or **Tomato**, to begin diversifying your food supply."]
	quest.4F1BAD0FF159CDF0.title: "New Harvests"
	quest.4F546AAC6F3D4963.quest_desc: ["The Campfire is your basic and most reliable heat source for cooking small ingredients and raw meats."]
	quest.4F546AAC6F3D4963.title: "Heat Source"
	quest.506BD7AA9AB36E8F.quest_desc: [
		"**Warrior Armor** (Iron/Lapis): Unleash a Berserk mode, dealing significantly more damage for every heart missing. For the Viking in you."
		"**Heavy Armor** (Iron/Toughness): Offers superior armor, high toughness, and dramatically reduced knockback, turning you into an unstoppable tank."
	]
	quest.506BD7AA9AB36E8F.title: "Tier 2: Combat and Tanking"
	quest.52453550206EC770.quest_desc: ["The **Dyer Hut** automates the production of various dyes, which are necessary for cosmetic changes to buildings, uniforms, and specific recipes."]
	quest.52453550206EC770.title: "Production: Dyer Hut"
	quest.52B3B09AB5BA8C90.quest_desc: ["**Stack Downgrades** reduce the stack size limit in a slot. This is useful for regulating automation inputs or ensuring certain item types don't fill up a large storage slot."]
