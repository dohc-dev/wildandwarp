	quest.461E28CA38F4FF8F.quest_desc: ["Blackstone is tier 4 material for tetra"]
	quest.461E28CA38F4FF8F.title: "More Dark Than Overworld"
	quest.468F6E0151E77E71.title: "A New Tool: The Empty Soul Catcher"
	quest.46ABE925335C066C.quest_desc: ["**Chipped** upgrades add the full functionality of Chipped's decoration workbenches to your backpack. Essential for creative building on the go."]
	quest.46ABE925335C066C.title: "Chipped Workbenches I"
	quest.48AC8545D66B71B7.quest_desc: ["Upgrading the **Builder's Hut** grants the Builder access to more complex schematics (larger buildings) and increases their maximum skill level."]
