	quest.2859F1B560AC334B.quest_desc: ["Moveable campfire"]
	quest.28EE13DE7CBE9518.quest_desc: ["The basic **Storage Upgrade Base** (Wood texture) is used to craft upgrades for Barrels, Chests, and Shulker Boxes."]
	quest.28EE13DE7CBE9518.quest_subtitle: "For Barrels, Chests, and Shulkers"
	quest.28EE13DE7CBE9518.title: "Storage Upgrade Base"
	quest.298B1994C646424F.quest_desc: ["The **Compression Upgrade** is a sophisticated version of the Compacting Upgrade, offering flexible block-to-item and item-to-block conversion logic."]
	quest.298B1994C646424F.title: "Compression Upgrade"
	quest.29D06B640C276146.quest_desc: ["Throw away energy"]
	quest.2A4D23849D9E75C0.quest_desc: ["Also holds liquids"]
	quest.2B01B964638DFBD1.quest_desc: ["The **Crusher Hut** is a basic processing unit that breaks down stone, cobblestone, and other blocks into raw resources for the Builder to use."]
	quest.2B01B964638DFBD1.title: "Production: Crusher Hut"
	quest.2B49C95AEE86C994.quest_desc: [
		"Check out the workshop to get some hands on experiance with some of the awesome new features of Areonautics. "
		""
		"That plane in the hangar isnt quite in working order, see if you can get it flying!"
	]
	quest.2B49C95AEE86C994.title: "Let's get flying!"
	quest.2D43DDEE8D229F42.quest_desc: ["Add the full range of **Chipped** decoration workbenches directly to your static storage blocks for easy access while crafting."]
	quest.2D43DDEE8D229F42.title: "Chipped Workbenches"
