	quest.4AEA30171CF1BFD7.quest_desc: [""]
	quest.4B2B22401FF12C27.quest_desc: ["The **Smoking** and **Blasting** upgrades add a portable Smoker (for food) and Blast Furnace (for ores) to your backpack, with Auto versions available."]
	quest.4B2B22401FF12C27.quest_subtitle: "Fast food and fast ores."
	quest.4B2B22401FF12C27.title: "Smoking and Blasting Upgrades"
	quest.4B8FC4B924A93366.quest_desc: ["The **Insulated Plate** (Vent Plate) is an excellent material for shields, offering significantly increased durability and resilience."]
	quest.4B8FC4B924A93366.title: "Reinforced Platework"
	quest.4C476592AA64996B.quest_subtitle: "Charges electric items, and can also be used to inflict damage to &cPlayers&r and &cMobs&r.&r"
	quest.4C476592AA64996B.title: "Craft &cTesla Coil"
	quest.4CEA538689841610.quest_desc: ["Immersive Armors adds visually unique and functionally powerful armor sets, moving beyond simple material progression. Each set offers exclusive effects, such as Berserk mode, anti-knockback, fire resistance, or double jump."]
