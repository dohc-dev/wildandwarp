	]
	quest.401990422501F5A3.title: "First Spawn"
	quest.40727A633E80B537.quest_desc: ["Sleep anywhere without changing your spawnpoint!"]
	quest.40B057390DF9F54D.quest_desc: ["Holds hot air for gaining altitude. can encase shafts."]
