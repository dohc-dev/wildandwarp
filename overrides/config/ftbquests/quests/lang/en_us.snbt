	quest.0000000080010000.quest_desc: ["Craft an **Acacia Cabinet** (or any wood type) for a dedicated food storage block on your farm or in your kitchen."]
	quest.0000000080010000.title: "Food Storage"
	quest.0000000080010003.quest_desc: ["Make a bowl meal like **Cabbage Rolls** or a **Beef Stew**. These full meals offer high saturation and are great for exploration."]
	quest.0000000080010003.title: "Basic Sustenance"
	quest.0000000080010007.quest_desc: ["Use your new **Skillet** to prepare a **Fried Egg** or cook some **Bacon**. Skillet recipes are quick ways to cook small meals."]
	quest.0000000080010007.title: "A Quick Fry"
	quest.000000008001000B.quest_desc: ["Prepare a decorative block meal like **Stuffed Pumpkin** or a **Roast Chicken Block**. These grant substantial bonuses and can feed multiple people."]
	quest.000000008001000B.title: "The Feast Block"
	quest.0000000080010023.quest_desc: ["The Slicer provides a means for mechanical cutting, speeding up the preparation of large batches of ingredients"]
	quest.0000000080010023.title: "Mechanical Slicing (Slice and Dice)"
	quest.0000000080010026.quest_desc: ["The Sprinkler automates crop watering"]
	quest.0000000080010026.title: "Efficient Farming (Slice and Dice)"
	quest.000000008001002A.quest_desc: ["Begin cultivating **Bell Peppers**, **Cotton**, and **Coffee Beans** to unlock the unique recipes offered by **Rustic Delight**."]
	quest.000000008001002A.title: "New Exotic Crops (Rustic Delight)"
	quest.000000008001002F.quest_desc: ["Craft **Syrup** to use as a primary sweetener in coffee, pancakes, and cookies. It is the liquid gold of the rustic kitchen."]
	quest.000000008001002F.title: "Liquid Gold (Syrup)"
	quest.0000000080010032.quest_desc: ["Bake a stack of **Pancakes**! Use **Syrup** or fruit for toppings to create a high-saturation breakfast."]
	quest.0000000080010032.title: "The Perfect Stack (Pancakes)"
	quest.0000000080010035.quest_desc: ["Roast your **Coffee Beans** and craft a simple **Coffee**. This provides a temporary boost to speed and focus."]
	quest.0000000080010035.title: "A Morning Brew (Coffee)"
	quest.0000000080010038.quest_desc: ["Combine coffee with milk, syrup, or chocolate to create advanced drinks like **Syrup Coffee** or **Chocolate Coffee**."]
	quest.0000000080010038.title: "Barista's Best"
	quest.000000008001003C.quest_desc: ["The **Squid Ink Pasta** is a high-tier specialty dish that uses squid to create a unique and flavorful meal."]
	quest.000000008001003C.title: "Ocean Harvest"
	quest.00925514C4C0BBCE.quest_desc: ["The **Extractor** attaches to the **Drilling Machine** to pull out mined ores. Use a simple item transport method (like belts or funnels) to collect the resources."]
	quest.00925514C4C0BBCE.title: "Collecting the Goods"
	quest.00A3AD4BD4EE0FC7.quest_desc: ["The **Guard Tower** is your first line of defense, providing a safe elevated position for guards to patrol and attack hostile mobs (or players) within the colony borders."]
	quest.00A3AD4BD4EE0FC7.title: "Build the Guard Tower"
	quest.00C8C2FAC2459375.quest_desc: ["The **Everlasting Upgrade** ensures that even if you die, the backpack and its contents remain in your inventory."]
	quest.00C8C2FAC2459375.quest_subtitle: "Keep inventory, permanently."
	quest.00C8C2FAC2459375.title: "Everlasting Upgrade"
	quest.011207A61DF23A64.quest_desc: ["The **Drilling Machine** is the central block for excavation. Place it directly above the center of a discovered ore vein (or where you think one is) and attach a **Drill Head** to start mining."]
	quest.011207A61DF23A64.title: "The Excavator Setup"
	quest.0146F1A6865A373B.quest_desc: ["**Treatise Scrolls** are obtained by trading with villagers and offer benefits like enhancing material forging quality or reducing the resource cost for component crafting."]
	quest.0146F1A6865A373B.title: "A Synergistic Approach (Treatise)"
	quest.0213C3F63A653227.quest_desc: ["A sturdy spot for connecting a rope"]
	quest.02C39AF9B0CDB5A4.quest_desc: ["Randomize block placement"]
	quest.030E3962451BB4BD.quest_desc: ["The **Storage Controller** links all *physically connected* Sophisticated storage blocks into a single network for automation. The **Storage Tool** allows you to view, configure, and link **Storage Links** wirelessly to the network."]
	quest.030E3962451BB4BD.quest_subtitle: "The key to your storage network."
	quest.030E3962451BB4BD.title: "Storage Controller and Network Tools"
	quest.03A6C339A6F203C6.quest_desc: ["Increase your luck!"]
	quest.03D3695417CE2B82.quest_desc: ["A large cog wheel with a crank"]
	quest.03DB76C4A4A1386B.quest_desc: ["The **Hopper Upgrade** acts as a powerful integrated hopper for automated insertion or extraction. The **Advanced** version allows filtering and other complex routing logic."]
	quest.03DB76C4A4A1386B.title: "Hopper Upgrades"
	quest.03F9939977753992.title: "Iron Backpack"
	quest.043D87F52A55D8F9.quest_desc: ["Works perfectly with the rock cutting wheel"]
	quest.04AC241FE350DD86.quest_desc: ["Good for handling a shipwreck "]
	quest.051E5008AF90F86B.quest_desc: ["A gearbox with more sides"]
	quest.05E72D0E7AC4B29A.quest_desc: ["The **Skillet** is used for recipes requiring frying or sautéing ingredients, often yielding delicious cooked patties and vegetable medleys."]
	quest.05E72D0E7AC4B29A.title: "Frying up Dinner"
	quest.0602CB99A77F9CB8.quest_desc: ["The ultimate in portable storage. The Netherite Backpack is fire-resistant and offers the most upgrade slots and storage space."]
	quest.0602CB99A77F9CB8.title: "Netherite Backpack"
	quest.06AFC3385C85BBD6.quest_desc: ["How many blocks long is that?"]
	quest.074223593520B23E.quest_desc: ["This chapter serves as your initiation into the **Tetra** mod, guiding you through its core mechanics and features."]
	quest.074223593520B23E.quest_subtitle: "Welcome to Tetra"
	quest.074223593520B23E.title: "Introduction to Tetra"
	quest.076C39593E801A5E.quest_desc: ["A propeller for generating thrust"]
	quest.085F473094778DCD.quest_desc: ["The **Resource Scroll** is a valuable utility item that can be used to instantly summon needed resources from the warehouse, or to place requested items into the warehouse."]
	quest.085F473094778DCD.title: "Utility: Resource Scroll"
	quest.08ACA2EAE7CB44AA.title: "Blasting Upgrades"
	quest.08CEE78252594F5F.quest_desc: ["Sophisticated Storage blocks can be instantly upgraded to higher tiers in the world using Tier Upgrades. Start with the **Basic to Copper** to unlock mid-game capacity."]
	quest.08CEE78252594F5F.quest_subtitle: "Right-click on your storage block to upgrade it."
	quest.08CEE78252594F5F.title: "Storage Tier Upgrades"
	quest.0902520ECB26E099.quest_desc: ["use a funnel to get fuel into your reactor"]
	quest.0ABA0995CC4AB6CB.quest_desc: ["Use the **Filter Upgrade** to define exactly what items can go in (or out) of the backpack. The **Advanced** version increases the filter slots."]
	quest.0ABA0995CC4AB6CB.quest_subtitle: "Input/Output Item Control"
	quest.0ABA0995CC4AB6CB.title: "Filter Upgrades"
	quest.0AC85C39CEEE118C.quest_desc: [
		"Mine Blocks from far away!"
		"(useful for mining on sky islands)"
	]
	quest.0B009391E3F76D6E.quest_desc: ["The **Fisherman Hut** provides a steady, hands-off source of fish. Place the hut over water and hire a Fisherman to keep your early food stocks filled."]
	quest.0B009391E3F76D6E.title: "Fisherman Hut"
	quest.0B12EBD18763F023.quest_desc: ["PONDER!"]
	quest.0BE6236A78C6894D.quest_desc: ["The **Compacting Upgrade** automatically converts items into their block form (e.g., nine iron ingots into an iron block) saving huge amounts of space."]
	quest.0BE6236A78C6894D.quest_subtitle: "Maximize block storage density."
	quest.0BE6236A78C6894D.title: "Compacting Upgrades"
	quest.0C2B7732BCF7BC81.quest_desc: ["Obtain the **Quick Latch** component, which can be used on a **Tool Belt** or a **Bow**. Experience the convenience of this rapid-use ability!"]
	quest.0C2B7732BCF7BC81.title: "Rapid Deployment Mechanism"
	quest.0D6E099A1A242153.quest_desc: [
		"The **Town Hall** is the heart of your colony, defining the colony boundaries and housing the Colony Control block."
		"Place the Town Hall block inside the deployment boundary you set with the **Supply Deployer**."
		"Use the **Block of Gold Scepter** to select the Town Hall block, choose a build style, and give it resources to start construction with the Builder."
	]
	quest.0D6E099A1A242153.title: "The Town Hall: Heart of the Colony"
	quest.0DCC41C7AEE63B32.quest_desc: ["A redstone powered burner for generating hot air"]
	quest.0DF990C01E668B43.quest_desc: ["The bow is a powerful projectile weapon, and its **Tetra** counterpart is no exception. Experiment with different bow components to maximize your strength."]
	quest.0DF990C01E668B43.title: "Master Archer's Weapon"
	quest.0E000B8A071C1F4B.quest_desc: ["absorbs exp orbs!"]
	quest.0E1056A87BB27BC9.quest_desc: ["Suround a Generator coil with magnitite to get &4FE POWER!&r"]
	quest.0E3C466668EDC434.quest_desc: ["Utilize the **Stonecutter** material on your sword to gain the special ability to **sweep-mine stone** and similar blocks."]
	quest.0E3C466668EDC434.title: "The Stone Carver Blade"
	quest.0EBB4E5195610A82.quest_desc: ["The **Sawmill** is an advanced wood production building that turns logs into planks, crafting items needed by the Builder, and can eventually craft advanced wood blocks."]
	quest.0EBB4E5195610A82.title: "Advanced Wood: Sawmill"
	quest.0ED823E6406CCC36.quest_desc: ["Its not magic its SCIENCE"]
	quest.0F409DACBEB7BBF8.quest_desc: ["The **Supply Chest Deployer** offers a more robust start than the Camp, providing a larger initial chest and more resources for the Town Hall construction."]
	quest.0F409DACBEB7BBF8.title: "Option: Supply Chest Deployer"
	quest.0F6777CAB70D17AE.quest_desc: ["The **Vein Finder** gives an initial direction to nearby veins. Try using poner on the Vein Atlas to see how it works"]
	quest.0F6777CAB70D17AE.title: "Advanced Prospecting (Atlas)"
	quest.10BC36D23A81AF11.quest_desc: ["The **Limited Barrel** series sacrifices inventory slots for enormous stack capacity, ideal for bulk storage of single item types like stone, wood, or dirt."]
	quest.10BC36D23A81AF11.quest_subtitle: "High density bulk storage."
	quest.10BC36D23A81AF11.title: "Limited Barrels"
	quest.10DF3D58FD817EF2.quest_desc: [
		"Upgrade hammer to tinker stronger item."
		"You need another hammer to upgrade."
		"(So I had gave you another above XD)"
	]
	quest.10DF3D58FD817EF2.title: "New Stone Age"
	quest.1157A9548EB3044A.quest_desc: ["Highly Conductive Metal"]
	quest.120152510AD4B59A.quest_desc: ["The **Build Goggles** allow you to see the outline of buildings *before* they are placed, helping you perfectly plan your colony layout."]
	quest.120152510AD4B59A.title: "Utility: Build Goggles"
	quest.125C1B72258B20FE.quest_subtitle: "The Electric motor generates kinetic energy from &cFE&r. The Alternator generates electricity from &9Rotational Force.&r"
	quest.125C1B72258B20FE.title: "Craft &cElectric Motor and Alternator"
	quest.128D971AEC6AC230.quest_desc: ["The **Ultimate Drill** is the pinnacle of the mod, capable of drilling any vein at maximum speed, regardless of its composition."]
	quest.128D971AEC6AC230.title: "Pinnacle Excavation"
	quest.130E8FC7479E4271.quest_desc: ["The **Shepherd Hut** manages a herd of sheep for wool production. They require shears to operate."]
	quest.130E8FC7479E4271.title: "Herder: Shepherd Hut"
	quest.1312B33261493897.quest_desc: ["Better magnets means MORE &4FE POWER&r"]
	quest.132AF80A62FFF98D.quest_desc: ["The **Tavern** is the hub for attracting new citizens. A higher level Tavern will draw new recruits more quickly. Ensure there is food in the system to encourage them to stay!"]
	quest.132AF80A62FFF98D.title: "Build the Tavern: Recruit Citizens"
	quest.138C764D48EB4127.title: "Welcome to the Farm"
	quest.14DA3DC7C0009A6A.quest_desc: ["The peak of colony population! **50** citizens is a massive achievement. Maintaining this population requires immense resource management and high-level buildings."]
	quest.14DA3DC7C0009A6A.title: "Population Milestone: 50 Citizens"
	quest.1501C5011A3702F2.quest_desc: ["Ponder me!"]
	quest.154A2371225585E9.quest_desc: ["You're gonna need some &4FE power&r and an &bEnergizer&r for this! "]
	quest.15B51FB56A64C303.quest_desc: ["The **University** is the primary building for training citizens into specialized roles, enabling high-level jobs like the Scholar, which can boost research speed and citizen quality."]
	quest.15B51FB56A64C303.title: "The University: Advanced Training"
	quest.15F03A5E7E14C022.quest_desc: ["The **Stonemason Hut** specializes in cutting, shaping, and crafting stone blocks and complex stone decorations needed for higher-tier buildings and specific schematics."]
	quest.15F03A5E7E14C022.title: "Advanced Stone: Stonemason"
	quest.167C5A3841D3B89F.quest_desc: [
		"The **Soul Catcher** is used to capture a mob's soul."
		"To work, the target mob must have an active **Weakness effect**, often applied with a throwable potion."
		"The time it takes to capture a mob depends on its hitbox volume, with smaller mobs being quicker."
		"Bosses cannot be captured."
	]
	quest.167C5A3841D3B89F.quest_subtitle: "Capture a mob's soul for spawning"
	quest.167C5A3841D3B89F.title: "Catching Souls"
	quest.172938CA9D2EF823.quest_desc: ["Vertical item vaults"]
	quest.1762E8D84A5D523D.quest_desc: ["The **Pickup** upgrade absorbs nearby drops into the barrel's inventory. The **Magnet** upgrade attracts items from a wider radius. Use the **Advanced** variants for filtering and greater range."]
	quest.1762E8D84A5D523D.title: "Pickup Upgrades"
	quest.187073F9830ECE79.quest_desc: ["Connect this to one side of your &2Reactor Rod&r"]
	quest.18922D8834A0CF95.quest_desc: ["Outputs a redstone signal baed on altitude. Also shows info about air pressure and altitude when wearing goggles"]
	quest.190D10907EC19AC1.quest_desc: ["Fuel for your reactor"]
	quest.194E863F24FFF1AD.quest_desc: ["Most standard tools can be converted into **Tetra** versions, which are modular, upgradeable, and grow stronger over time. Simply place your double- or single-headed tools into the workbench to begin!"]
	quest.194E863F24FFF1AD.title: "Forging Superior Tools"
	quest.19D03831EB5EED02.quest_desc: ["The **Blacksmith** is responsible for crafting all metal tools, weapons, and armor required by your citizens and military forces."]
	quest.19D03831EB5EED02.title: "Production: Blacksmith Hut"
	quest.1A17EFA6931E49CC.quest_desc: ["it only connects if the input is spinning in the right direction"]
	quest.1B48D15EF425C8C9.quest_desc: ["a small tire"]
	quest.1BB571557F74D3A1.quest_desc: [
		"MineColonies allows you to build a thriving player-run civilization. You recruit NPCs, assign them jobs, and manage all resources needed for growth."
		""
		"The journey starts by obtaining a **Supply Camp** or **Supply Chest** deployer."
	]
	quest.1BB571557F74D3A1.title: "Welcome to MineColonies"
	quest.1BFEBF8CC804D3AB.quest_desc: ["A better solar heater!"]
	quest.1C16AEE8E29FB5A0.quest_desc: ["The **Rally Banner** is a military utility block used to summon all guards to a specific location for defense or a planned attack."]
	quest.1C16AEE8E29FB5A0.title: "Military: Rally Banner"
	quest.1C29150EA7A53EFC.quest_desc: ["No more water everywhere!"]
	quest.1C910B0F5B827E9B.quest_desc: [
		"Build your first hammer to start tetra."
		"Another crafting table can build workbench."
	]
	quest.1C910B0F5B827E9B.title: "Your First Hammer"
	quest.1CA1F6BC2F508536.quest_desc: ["A gearshift but backwards"]
	quest.1D267ADE18DD9817.quest_desc: [
		"The &6printer&r will take any enchanted book by right clicking on it to save the enchantments you want to print onto new books."
		""
		"As long as the printer is given enough liquid xp it will make a duplicate of the book you have given it"
		""
		"You can also duplicate books you have written in by giving it the written book, then giving the &6printer&r liquid ink &a(made in the mixer)&r"
	]
	quest.1D267ADE18DD9817.quest_subtitle: "Enchanted Book Duplication kind of"
	quest.1E1870FAD295DEDE.quest_desc: ["The **Supply Camp Deployer** sets up a temporary construction site with a chest for the initial Town Hall build. This is the simple start for a new colony."]
	quest.1E1870FAD295DEDE.title: "Option: Supply Camp Deployer"
	quest.1E3B2C2A5B3F8891.quest_desc: ["The **Compacting Upgrade** automatically converts items into blocks and vice versa. Essential for maximizing storage density of metal and stone resources."]
	quest.1E3B2C2A5B3F8891.title: "Compacting Upgrades"
	quest.1E9890769102E276.quest_desc: ["Generates rotational force when fed with &8coal&r or &4blaze cakes&r"]
	quest.1E99ACD96AD8A826.quest_desc: ["connect two blocks together with a spring! use a wrench to change its strength"]
	quest.1EEED0E88E2869EB.quest_desc: ["A precise source of redstone power"]
	quest.1F6879A74DD18F0B.quest_desc: ["a REALLY big tire"]
	quest.1F879560512B92E5.quest_desc: ["The **Filter Upgrade** provides fine-grained control over which items can be inserted or extracted from the storage block."]
	quest.1F879560512B92E5.title: "Filter Upgrades"
	quest.1F8C7E4FF3FCF23B.quest_desc: ["Ya cant catch ME!!"]
	quest.1F8C7E4FF3FCF23B.title: "WHO IS THE MUFFIN MAN!?"
	quest.1FC3C1EC91AD1443.quest_desc: ["The **Jukebox Upgrade** allows you to play records placed in the storage block. The **Advanced** version adds multiple slots and playback controls."]
	quest.1FC3C1EC91AD1443.title: "Jukebox Upgrades"
	quest.201CB898A399F1D5.quest_desc: ["The **Swineherder Hut** manages a herd of pigs for pork and leather production."]
	quest.201CB898A399F1D5.title: "Herder: Swineherder Hut"
	quest.203A0C651EA25098.quest_desc: ["The **Magnet Upgrade** constantly attracts items, similar to the backpack version. It can be paired with a filter for targeted collection."]
	quest.203A0C651EA25098.title: "Magnet Upgrades"
	quest.206159A3C7A78447.quest_desc: ["The **Mystical Site** opens the door to high-level magic-based production and resources. An excellent long-term goal for advanced colonies."]
	quest.206159A3C7A78447.title: "Production: Mystical Site"
	quest.20B6827D7EBF60D3.quest_desc: ["Acts like a blaze burner! just add some &4HEAT&r"]
	quest.20D05EB3BBB0FAAB.quest_desc: ["a big tire"]
	quest.21B2D54BEC60EEBA.quest_desc: ["The &6item drain&r has the ability to take liquid out of a container and then it stores it until it it is piped out into a container"]
	quest.21B2D54BEC60EEBA.quest_subtitle: "Fluid extraction"
	quest.21F20E65F0CF4FB7.quest_desc: ["Sophisticated Storage blocks offer immense, modular capacity. Craft a basic Chest or Barrel. Right-click with a **Packing Tape** to pick it up fully loaded."]
	quest.21F20E65F0CF4FB7.title: "Sophisticated Chests and Barrels"
	quest.22F4C38E79DEFF1E.quest_desc: ["The **Town Hall Block** must be placed within the claimed territory to establish the official center of your colony. Choose a safe spot, as this block cannot be moved once placed!"]
	quest.22F4C38E79DEFF1E.title: "Place the Town Hall Block"
	quest.23012F6C4C522CEB.quest_desc: ["The **Lumberjack Hut** is your primary source of wood. Recruit a Lumberjack and they will chop down trees in their designated work area (set with the Build Tool)."]
	quest.23012F6C4C522CEB.title: "Lumberjack Hut"
	quest.2316FFE66B36924B.title: "Chipped Workbenches II"
	quest.2342ED0D00362854.quest_desc: ["Zipline by right clicking with a wrench! Use shears to cut it."]
	quest.238BD8E064D2D4CB.quest_desc: ["The **Prismarine Armor** (Prismarine) is a heavy set that grants permanent Depth Strider for fast underwater movement. Its sharp texture causes spike damage to any mobs that attack you."]
	quest.238BD8E064D2D4CB.title: "Tier 3: Aquatic Spikes"
	quest.2421FAEB8BE21B1D.quest_desc: ["P O N D E R"]
	quest.25606F0A9C843721.quest_desc: ["Atempts to face upwards along only one axis"]
	quest.25AFA8426F16F7DE.quest_desc: ["its a grappling hook!"]
